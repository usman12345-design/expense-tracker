{
  "name": "usmanshakeel/expense-pilot",
  "description": "A professional expense tracking application built for my portfolio.",
  "type": "project",
"require": {
    "php": "^8.4",
    "ext-bcmath": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "doctrine/dbal": "^4.4",
    "doctrine/migrations": "^3.9",
    "doctrine/orm": "^3.6",
    "php-di/php-di": "^7.1",
    "slim/psr7": "^1.8",
    "slim/slim": "4.*",
    "slim/twig-view": "^3.4",
    "symfony/cache": "^7.4",
    "symfony/console": "^7.4",
    "symfony/twig-bridge": "^7.4",
    "symfony/var-exporter": "^7.4",
    "symfony/webpack-encore-bundle": "^2.3",
    "twig/intl-extra": "^3.26",
    "twig/twig": "^3.28",
    "vlucas/phpdotenv": "^5.6",
    "vlucas/valitron": "^1.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }       
  },
  "autoload-dev": {
    "psr-4": {
        "Tests\\": "tests/"
     }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "symfony/var-dumper": "^7.0"
  },
  "scripts": {
    "post-autoload-dump": [
      "echo Autoload generated successfully"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
